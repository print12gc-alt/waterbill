<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Enter a meter reading for <%= house.name %>">
  <title><%= house.name %> — WUC Water Meter</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="watermark">WUC</div>
  <div class="container">

    <nav class="nav-row">
      <a href="/" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        All Properties
      </a>
      <span style="font-size:0.85rem;color:#64748b;margin-left:auto;">
        <strong><%= user.house_name %></strong>
      </span>
      <a href="/logout" class="back-link">Logout</a>
    </nav>

    <div class="page-header">
      <div class="icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
      </div>
      <div>
        <h1><%= house.name %></h1>
        <p class="subtitle">Enter the current meter reading to calculate your bill</p>
      </div>
    </div>

    <% if (error === 'invalid') { %>
      <div class="alert error">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
          <line x1="12" y1="9" x2="12" y2="13"/>
          <line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        <span>Please enter a valid meter reading (a positive number).</span>
      </div>
    <% } %>
    <% if (error === 'negative') { %>
      <div class="alert error">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
          <line x1="12" y1="9" x2="12" y2="13"/>
          <line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        <span>New reading cannot be less than the previous reading (<%= lastReading.meter_reading %> kL).</span>
      </div>
    <% } %>

    <% if (lastReading) { %>
      <div class="card reading-card">
        <h3>Previous Reading</h3>
        <span class="big-val"><%= lastReading.meter_reading %> kL</span>
        <p>Recorded on <%= lastReading.reading_date %> &mdash; usage <%= lastReading.consumption %> kL &mdash; bill P<%= lastReading.total_charge.toFixed(2) %></p>
      </div>
    <% } else { %>
      <div class="card reading-card">
        <h3>First Reading</h3>
        <p>No previous readings found. Enter the current meter reading and your bill will be calculated from 0 kL.</p>
      </div>
    <% } %>

    <div class="card form-card">
      <h3>Current Meter Reading</h3>
      <form action="/house/<%= house.id %>/reading" method="POST">
        <div>
          <label for="meter_reading">Meter Reading</label>
          <div class="input-wrap">
            <input type="number" step="0.001" min="0" id="meter_reading" name="meter_reading"
                   placeholder="<%= lastReading ? (lastReading.meter_reading + 10).toFixed(1) : '0.000' %>"
                   required autofocus>
            <span class="input-unit">kL</span>
          </div>
        </div>
        <button type="submit">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Calculate Bill
        </button>
      </form>
    </div>

    <div class="action-row">
      <a href="/house/<%= house.id %>/history" class="btn-link primary">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        View Bill History
      </a>
    </div>

  </div>
</body>
</html>
