<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Bill history for <%= house.name %>">
  <title>History — <%= house.name %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="watermark">WUC</div>
  <div class="container">

    <nav class="nav-row">
      <a href="/house/<%= house.id %>" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        <%= house.name %>
      </a>
      <a href="/" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Home
      </a>
      <span style="font-size:0.85rem;color:#64748b;margin-left:auto;">
        <strong><%= user.house_name %></strong>
      </span>
      <a href="/logout" class="back-link">Logout</a>
    </nav>

    <div class="page-header">
      <div class="icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      </div>
      <div>
        <h1><%= house.name %></h1>
        <p class="subtitle">
          <%= readings.length > 0 ? readings.length + ' reading' + (readings.length !== 1 ? 's' : '') + ' recorded' : 'No readings yet' %>
        </p>
      </div>
    </div>

    <% if (readings.length === 0) { %>
      <div class="alert info">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="16" x2="12" y2="12"/>
          <line x1="12" y1="8" x2="12.01" y2="8"/>
        </svg>
        <span>No readings have been recorded for this property yet.</span>
      </div>
    <% } else { %>
      <table class="history-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Meter Reading</th>
            <th>Consumption</th>
            <th>Total Bill</th>
          </tr>
        </thead>
        <tbody>
          <% readings.forEach(r => { %>
            <tr>
              <td><%= r.reading_date %></td>
              <td><%= r.meter_reading %> kL</td>
              <td><%= r.consumption %> kL</td>
              <td class="amount">P<%= r.total_charge.toFixed(2) %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>

    <div class="action-row" style="margin-top:20px;">
      <a href="/house/<%= house.id %>" class="btn-link primary">
        <svg class="btn-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        New Reading
      </a>
      <a href="/" class="btn-link">
        <svg class="btn-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        All Properties
      </a>
    </div>

  </div>
</body>
</html>
